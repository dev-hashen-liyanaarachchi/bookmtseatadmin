<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header with Back Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_revert"
                android:tint="#FFC107" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Booking Details"
                android:textColor="#FFC107"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Booking Details Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Booking ID -->
                <TextView
                    android:id="@+id/tvBookingId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Booking ID: BMS-123456"
                    android:textColor="#FFC107"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Status -->
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="Status: PENDING"
                    android:textColor="#F44336"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="#333333" />

                <!-- Movie -->
                <TextView
                    android:id="@+id/tvMovie"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Movie: Avatar 2"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <!-- Seats -->
                <TextView
                    android:id="@+id/tvSeats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Seats: S1, S2, S3"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <!-- Amount -->
                <TextView
                    android:id="@+id/tvAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Total: LKR 3600"
                    android:textColor="#FFC107"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="#333333" />

                <!-- User Info -->
                <TextView
                    android:id="@+id/tvUserInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User: user@email.com\nUser ID: user123"
                    android:textColor="#888888"
                    android:textSize="14sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Issue Ticket Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnIssueTicket"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="Issue Ticket"
            android:textAllCaps="false"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#FFC107"
            app:cornerRadius="28dp" />

        <!-- Mark Attendance Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMarkAttendance"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Mark Attendance"
            android:textAllCaps="false"
            android:textColor="#FFC107"
            app:backgroundTint="#1A1A1A"
            app:cornerRadius="28dp"
            app:strokeColor="#FFC107"
            app:strokeWidth="1dp" />

    </LinearLayout>
</ScrollView>