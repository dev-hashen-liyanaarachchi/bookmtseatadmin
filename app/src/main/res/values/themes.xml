<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Theme.BookMySeatAdmin" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/yellow</item>
        <item name="colorPrimaryVariant">@color/dark_gray</item>
        <item name="colorOnPrimary">@color/black</item>

        <!-- Secondary colors -->
        <item name="colorSecondary">@color/yellow</item>
        <item name="colorSecondaryVariant">@color/dark_gray</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Background colors -->
        <item name="android:colorBackground">@color/black</item>
        <item name="colorSurface">@color/dark_gray</item>
        <item name="colorOnSurface">@color/white</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/light_gray</item>

        <!-- Button styles -->
        <item name="materialButtonStyle">@style/Widget.BookMySeatAdmin.Button</item>
    </style>

    <!-- Custom Button Style -->
    <style name="Widget.BookMySeatAdmin.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/black</item>
        <item name="backgroundTint">@color/yellow</item>
        <item name="cornerRadius">28dp</item>
    </style>

    <!-- Outlined Button Style -->
    <style name="Widget.BookMySeatAdmin.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/yellow</item>
        <item name="strokeColor">@color/yellow</item>
        <item name="strokeWidth">1dp</item>
    </style>
</resources>